# Exclude everything that's not needed in the Docker image.
# This speeds up `gcloud builds submit` by reducing the upload size.

# Git
.git
.gitignore

# Local env files — secrets must NEVER be baked into the image
.env
.env.*
!.env.example

# Next.js build cache & local output
.next
out

# Node modules (rebuilt inside Docker from package.json)
node_modules

# Dev & test files
*.log
*.md
test-*.js
coverage

# Editor / OS
.DS_Store
.vscode
.idea
